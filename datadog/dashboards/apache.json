{
  "title": "Apache",
  "description": null,
  "layout_type": "free",
  "template_variables": [
    {
      "name": "env",
      "prefix": "env",
      "default": "challenge"
    }
  ],
  "widgets": [
    {
      "definition": {
        "type": "query_value",
        "title": "REQUESTS/S",
        "requests": [
          {
            "q": "avg:apache.net.request_per_s{$env}",
            "aggregator": "avg"
          }
        ],
        "precision": 1,
        "timeseries_background": {
          "type": "bars"
        }
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 32,
        "height": 20
      },
      "id": 5882686940303752
    },
    {
      "definition": {
        "type": "query_value",
        "title": "WORKER SATURATION",
        "requests": [
          {
            "formulas": [
              {
                "formula": "(query1 / query2) * 100",
                "conditional_formats": [
                  {
                    "comparator": ">=",
                    "value": 85,
                    "palette": "white_on_red"
                  },
                  {
                    "comparator": ">=",
                    "value": 60,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": "<",
                    "value": 60,
                    "palette": "white_on_green"
                  }
                ]
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "query1",
                "query": "avg:apache.performance.busy_workers{$env}"
              },
              {
                "data_source": "metrics",
                "name": "query2",
                "query": "avg:apache.performance.max_workers{$env}"
              }
            ],
            "response_format": "scalar"
          }
        ],
        "precision": 1,
        "custom_unit": "%",
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 36,
        "y": 0,
        "width": 32,
        "height": 20
      },
      "id": 1884543947297688
    },
    {
      "definition": {
        "type": "query_value",
        "title": "THROUGHPUT",
        "requests": [
          {
            "q": "avg:apache.net.bytes_per_s{$env}",
            "aggregator": "avg"
          }
        ],
        "precision": 0,
        "custom_unit": "B/s",
        "timeseries_background": {
          "type": "area"
        }
      },
      "layout": {
        "x": 72,
        "y": 0,
        "width": 32,
        "height": 20
      },
      "id": 3055520233225808
    },
    {
      "definition": {
        "type": "query_value",
        "title": "CPU LOAD",
        "requests": [
          {
            "q": "avg:apache.performance.cpu_load{$env}",
            "aggregator": "avg",
            "conditional_formats": [
              {
                "comparator": ">=",
                "value": 80,
                "palette": "white_on_red"
              },
              {
                "comparator": ">=",
                "value": 50,
                "palette": "white_on_yellow"
              },
              {
                "comparator": "<",
                "value": 50,
                "palette": "white_on_green"
              }
            ]
          }
        ],
        "precision": 1,
