    {
      "definition": {
        "type": "query_value",
        "title": "ERROR RATE",
        "custom_unit": "%",
        "precision": 2,
        "timeseries_background": {
          "type": "area"
        },
        "requests": [
          {
            "formulas": [
              {
                "formula": "(errors / hits) * 100",
                "conditional_formats": [
                  {
                    "comparator": ">",
                    "value": 5,
                    "palette": "white_on_red"
                  },
                  {
                    "comparator": ">",
                    "value": 2,
                    "palette": "white_on_yellow"
                  },
                  {
                    "comparator": "<=",
                    "value": 2,
                    "palette": "white_on_green"
                  }
                ]
              }
            ],
            "queries": [
              {
                "data_source": "metrics",
                "name": "errors",
                "query": "sum:trace.flask.request.errors{service:python-flask,$env}.as_count()"
              },
              {
                "data_source": "metrics",
                "name": "hits",
                "query": "sum:trace.flask.request.hits{service:python-flask,$env}.as_count()"
              }
            ],
            "response_format": "scalar"
          }
        ]
      },
      "layout": {
        "x": 0,
        "y": 5,
        "width": 34,
        "height": 28
      },
      "id": 2197110807651425
    },
