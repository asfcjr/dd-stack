{
  "name": "[Challenge] Pod in CrashLoopBackOff",
  "type": "query alert",
  "query": "sum(last_5m):sum:kubernetes_state.container.status_report.count.waiting{reason:crashloopbackoff} by {pod_name,kube_namespace} >= 1",
  "message": "{{#is_alert}}Pod {{pod_name.name}} ({{kube_namespace.name}}) em CrashLoopBackOff.{{/is_alert}}\n@antoniosergiof@outlook.com\n@slack-alerts",
  "tags": [
    "env:challenge"
  ],
  "options": {
    "thresholds": {
      "critical": 1.0
    },
    "notify_no_data": false,
    "notify_audit": false,
    "new_host_delay": 300,
    "include_tags": true,
    "silenced": {}
  },
  "priority": null
}